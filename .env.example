# Copy this file to `.env` and paste your AlphaAI API key.
# Create a key at https://alphai.io/account/api-keys
#
#   cp .env.example .env
#
# The SDK (and every example here) reads ALPHAI_API_KEY from the environment.
ALPHAI_API_KEY=ak_live_your_key_here

# ───────────────────────────────────────────────────────────────────────────
# news-alert bot (alerts/) — everything below is OPTIONAL. With none of it set,
# the bot runs in console-only mode against a default sample watchlist.
# ───────────────────────────────────────────────────────────────────────────

# Comma-separated tickers to watch. Use "trending" for whole-market mode.
# Default when unset: NVDA,AAPL,MSFT,TSLA
# WATCHLIST=NVDA,AAPL,MSFT,TSLA

# Filtering / polling
# MIN_RELEVANCE=7              # 1–10 (default 7)
# CATEGORIES=earnings,insider  # only these categories (optional)
# EXCLUDE_CATEGORIES=crypto    # drop these categories (optional)
# PER_TICKER_LIMIT=5           # max articles per ticker per poll (default 5)
# POLL_INTERVAL_SECONDS=300    # --watch poll cadence (default 300)
# STATE_FILE=.alerts-state.json
# FIRST_RUN_BACKFILL=0         # deliver N newest on first run, else seed silently

# Delivery channels — set the ones you want; the rest stay off.
# Slack Incoming Webhook:   https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# Telegram Bot API (talk to @BotFather for a token; @userinfobot for a chat id):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890

# Any JSON POST target (Zapier / Make / n8n / your own server):
# WEBHOOK_URL=https://example.com/hooks/alphai
